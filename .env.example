# Database — Railway provides DATABASE_URL automatically when you add the Postgres plugin
DATABASE_URL=postgres://user:password@localhost:5432/phillyzon

# Session — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-string

# Server
PORT=5000
NODE_ENV=development

# Cloudflare R2 — for image uploads (menu photos, promotions)
# Find Account ID at: dash.cloudflare.com → R2 → Overview (right sidebar)
# Create API token at: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=phillyzon-uploads
# Public URL for the bucket — set after enabling public access in R2 settings
# e.g. https://images.phillyzon.com  or  https://pub-xxxx.r2.dev
R2_PUBLIC_URL=https://images.phillyzon.com
